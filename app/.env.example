# Security root — infra (the keystone control plane).
# Set INFRA_URL and the rune runtime auto-wires the infra token-exchange client,
# the offline JWKS verifier, and the revocation poller (it logs "INFRA_URL not
# set — ... only trusted origins authorize" when absent). Endpoints then authorize
# with @Public / @Roles / @claims + getIdentity. Leave it unset for local desktop
# use: localhost is trusted and SSR reads the backend in-process.
# INFRA_URL=https://infra.internal

# Trust the loopback peer (default true). Set false in networked/production deploys.
# TRUST_LOCALHOST=true

# Verify browser users against the shared keystone Firebase project (optional).
# FIREBASE_PROJECT_ID=

# Backend listen port (the desktop shell uses an ephemeral port regardless).
# PORT=3000
