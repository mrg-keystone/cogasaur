{
  "workspace": [
    "./server",
    "./ui"
  ],
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "imports": {
    "@sprig/core": "jsr:@sprig/core@^0.12.7",
    "@sprig/keep": "jsr:@sprig/core@^0.12.7/keep",
    "@webview/webview": "jsr:@webview/webview@0.9.0"
  },
  "tasks": {
    "sync": "rune sync server/src/info/info.rune",
    "build": "deno run -A jsr:@sprig/core/cli build ui",
    "start": "deno serve -A --unstable-kv --node-modules-dir=auto serve.ts",
    "dev": "deno run -A jsr:@sprig/core/cli dev ui",
    "desktop": "deno task build && deno run -A --unstable-ffi --unstable-kv --node-modules-dir=auto shell.ts"
  },
  "nodeModulesDir": "auto",
  "lock": false
}
